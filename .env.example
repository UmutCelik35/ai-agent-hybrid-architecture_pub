# =========================
# LLM CONFIG
# =========================
GOOGLE_API_KEY="your-google-api-key"
OPENAI_API_KEY="your-openai-api-key"
LLM_MODEL_NAME="gpt_4o"


# =========================
# XRAY JIRA CONFIG
# =========================
# Used by both Cloud and Data Center. Valid values: datacenter, cloud.
XRAY_DEPLOYMENT="datacenter"

# Data Center only. Jira base URL and token used by Jira REST and Xray Raven REST endpoints.
JIRA_DATACENTER_URL="https://jira.example.com"
JIRA_DATACENTER_API_TOKEN="your-jira-bearer-token"
JIRA_DATACENTER_VERIFY_SSL="false"

# Cloud only. Jira Cloud REST API credentials.
JIRA_CLOUD_URL="https://your-domain.atlassian.net"
JIRA_CLOUD_EMAIL="your-email@example.com"
JIRA_CLOUD_API_TOKEN="your-atlassian-api-token"

# Cloud only. Xray Cloud API credentials.
XRAY_CLOUD_API_URL="https://xray.cloud.getxray.app"
XRAY_CLOUD_CLIENT_ID=""
XRAY_CLOUD_CLIENT_SECRET=""

# =========================
# BUG CREATE CONFIG
# =========================
BUG_PROJECT_KEY="YOUR_PROJECT_KEY"
BUG_ISSUE_TYPE_ID="YOUR_ISSUE_TYPE_ID"
BUG_TYPE_FIELD_ID="customfield_xxxxx"
BUG_TYPE_OPTION_ID="xxxxx"
BUG_CREATION_MODE="review"
BUG_REVIEW_UI_AUTO_OPEN="true"

# =========================
# STATIC TOOLBOX CONFIG
# =========================
STATIC_TOOLBOX_MODE="off"
STATIC_PLAYWRIGHT_HEADLESS="false"
STATIC_SELF_HEALING_ENABLED="true"
STATIC_LLM_ROUTER_ENABLED="true"
STATIC_TOOL_SUGGESTIONS_ENABLED="true"
STATIC_DEFAULT_APP_NAME="greenkart"
STATIC_HEALING_MAX_RETRIES="1"
STATIC_HEALING_HTML_LIMIT="4000"
